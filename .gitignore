# --- Rust / Cargo ---
# The following directories are generated by the build process.
/target/

# Remove this if you want to lock your dependencies to specific versions.
# Usually kept for binaries, ignored for libraries.
# Cargo.lock

# Backup files generated by cargo
**/*.rs.bk

# --- JetBrains / RustRover ---
# Contains IDE-specific project settings.
.idea/
*.iml

# If you want to share specific settings (like code style or run configs),
# uncomment the following lines and add them to your repo:
# !.idea/vcs.xml
# !.idea/codeStyles/
# !.idea/runConfigurations/

# --- Mermaid / Documentation ---
# If you use Mermaid CLI (mmdc) to render diagrams to static files,
# ignore the output formats to keep the repo clean.
*.png
*.svg
*.pdf
# Ignore Mermaid error logs
*.err
*.log

# --- OS / Environment ---
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
desktop.ini

# Linux
.fuse_hidden
.directory
.Trash-*

# Environment Variables
.env
.env.local